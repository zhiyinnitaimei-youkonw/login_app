<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="20dp"
    android:layout_margin="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择头像"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <ImageView android:id="@+id/avatar_1" android:layout_width="56dp"
            android:layout_height="56dp" android:src="@drawable/avatar_1"
            android:layout_margin="6dp"/>
        <ImageView android:id="@+id/avatar_2" android:layout_width="56dp"
            android:layout_height="56dp" android:src="@drawable/avatar_2"
            android:layout_margin="6dp"/>
        <ImageView android:id="@+id/avatar_3" android:layout_width="56dp"
            android:layout_height="56dp" android:src="@drawable/avatar_3"
            android:layout_margin="6dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView android:id="@+id/avatar_4" android:layout_width="56dp"
            android:layout_height="56dp" android:src="@drawable/avatar_4"
            android:layout_margin="6dp"/>
        <ImageView android:id="@+id/avatar_5" android:layout_width="56dp"
            android:layout_height="56dp" android:src="@drawable/avatar_5"
            android:layout_margin="6dp"/>
        <ImageView android:id="@+id/avatar_6" android:layout_width="56dp"
            android:layout_height="56dp" android:src="@drawable/avatar_6"
            android:layout_margin="6dp"/>
    </LinearLayout>

</LinearLayout>
